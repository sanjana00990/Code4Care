<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/alert_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    tools:context=".AlertStatusActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_alert"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_dark"
        app:title="@string/alert_title"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar_alert"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md">

            <!-- Alert Active Indicator (initially GONE) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_alert_active"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/danger_red_bg"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:id="@+id/tv_emergency_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emergency_triggered"
                        android:textSize="@dimen/text_headline"
                        android:textColor="@color/danger_red"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tv_alert_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/alert_active"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/danger_red"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.2"
                        android:layout_marginTop="@dimen/spacing_xs" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- No Active Alert (shown when no alert) -->
            <LinearLayout
                android:id="@+id/layout_no_alert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_check_circle"
                    android:alpha="0.4"
                    android:contentDescription="All safe" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_active_alert"
                    android:textSize="@dimen/text_title"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="@dimen/spacing_md" />

                <TextView
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:text="@string/no_alert_description"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>

            <!-- Progress Steps Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_progress_steps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/card_alert_active"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Step 1: Emergency Detected -->
                    <LinearLayout
                        android:id="@+id/step_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/spacing_md">

                        <ImageView
                            android:id="@+id/icon_step_1"
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:src="@drawable/ic_check_circle"
                            android:contentDescription="Step 1" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/step_emergency_detected"
                                android:textSize="@dimen/text_subtitle"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_step1_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_complete"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/safe_green"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                    <!-- Step 2: SMS Sent -->
                    <LinearLayout
                        android:id="@+id/step_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/spacing_md">

                        <ImageView
                            android:id="@+id/icon_step_2"
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:src="@drawable/ic_check_circle"
                            android:contentDescription="Step 2" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/step_sms_sent"
                                android:textSize="@dimen/text_subtitle"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_step2_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_in_progress"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/monitoring_amber"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                    <!-- Step 3: Location Shared -->
                    <LinearLayout
                        android:id="@+id/step_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/spacing_md">

                        <ImageView
                            android:id="@+id/icon_step_3"
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:src="@drawable/ic_check_circle"
                            android:alpha="0.3"
                            android:contentDescription="Step 3" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/step_location_shared"
                                android:textSize="@dimen/text_subtitle"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_step3_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_pending"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                    <!-- Step 4: Authorities Notified -->
                    <LinearLayout
                        android:id="@+id/step_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/spacing_md">

                        <ImageView
                            android:id="@+id/icon_step_4"
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:src="@drawable/ic_check_circle"
                            android:alpha="0.3"
                            android:contentDescription="Step 4" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/step_authorities_notified"
                                android:textSize="@dimen/text_subtitle"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tv_step4_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status_pending"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/layout_alert_actions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_lg"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/card_progress_steps"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_alert"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_cancel_alert"
                    android:textColor="@color/text_primary"
                    style="@style/Widget.SafeGuard.Button.Outlined"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_im_safe"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_im_safe"
                    style="@style/Widget.SafeGuard.Button"
                    app:backgroundTint="@color/safe_green"
                    android:layout_marginStart="@dimen/spacing_sm" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
