<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:padding="24dp">

    <!-- App Logo / Title -->
    <TextView
        android:id="@+id/tv_role_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SafeGuard"
        android:textSize="32sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/tv_role_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Who are you?"
        android:textSize="14sp"
        android:textColor="@color/text_hint"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_role_app_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Parent Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_parent"
        android:layout_width="0dp"
        android:layout_height="180dp"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        android:layout_marginTop="48dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/tv_role_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍👧"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parent / Guardian"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitor your child's safety in real-time"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Child Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_child"
        android:layout_width="0dp"
        android:layout_height="180dp"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        android:layout_marginTop="16dp"
        android:foreground="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/card_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🙋‍♀️"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Child / User"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send SOS alerts and share your location"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Accent border on selected Parent card -->
    <View
        android:id="@+id/divider_role"
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:background="@color/accent"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/card_child"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a role to continue"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider_role"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
