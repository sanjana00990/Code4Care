<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_guardian"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_guardian"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Guardian Dashboard"
            app:titleTextColor="@color/text_primary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <!-- ── Live Status Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_live_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE STATUS"
                        android:textSize="11sp"
                        android:textColor="@color/accent"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <View
                            android:id="@+id/view_status_dot_guardian"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_dot_active" />

                        <TextView
                            android:id="@+id/tv_guardian_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Connecting…"
                            android:textSize="22sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="10dp" />

                        <TextView
                            android:id="@+id/tv_status_badge_guardian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE"
                            android:textSize="11sp"
                            android:textColor="@color/safe_green"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/bg_status_safe"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginVertical="12dp" />

                    <!-- Last Updated -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last update: "
                            android:textSize="13sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:id="@+id/tv_last_updated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <!-- Alert Message (shown on emergency) -->
                    <TextView
                        android:id="@+id/tv_alert_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/danger_red"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Live Location Map Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_map"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE LOCATION"
                        android:textSize="11sp"
                        android:textColor="@color/accent"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:padding="16dp"
                        android:paddingBottom="8dp" />


                    <!-- OpenStreetMap View (no API key needed) -->
                    <org.osmdroid.views.MapView
                        android:id="@+id/map_view"
                        android:layout_width="match_parent"
                        android:layout_height="240dp" />

                    <!-- Coordinates Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:paddingTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LATITUDE"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tv_guardian_lat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LONGITUDE"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tv_guardian_lon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── One-Tap Action Buttons ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUICK ACTIONS"
                        android:textSize="11sp"
                        android:textColor="@color/accent"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Call Police -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_call_police"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="🚨  Call Police"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/danger_red"
                            app:cornerRadius="12dp" />

                        <!-- Open in Maps -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_maps"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="📍  Open Maps"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/accent"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Recent Alerts Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_recent_alerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECENT ALERTS"
                        android:textSize="11sp"
                        android:textColor="@color/accent"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_no_alerts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No recent alerts. All is well 💚"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:gravity="center"
                        android:padding="16dp" />

                    <LinearLayout
                        android:id="@+id/layout_alerts_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
