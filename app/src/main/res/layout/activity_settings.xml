<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    tools:context=".SettingsActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_settings"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_dark"
        app:title="@string/settings_title"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/toolbar_settings"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- ═══ MY PROFILE SECTION ═══ -->
            <TextView
                android:id="@+id/tv_section_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_profile"
                style="@style/TextAppearance.SafeGuard.SectionHeader"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_my_name"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_my_name"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/et_my_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_my_name"
                        android:inputType="textPersonName"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:background="@drawable/bg_input_field"
                        android:padding="@dimen/spacing_md"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:importantForAutofill="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_my_phone_number"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/desc_my_phone_number"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/et_my_phone_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_my_phone_number"
                        android:inputType="phone"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:background="@drawable/bg_input_field"
                        android:padding="@dimen/spacing_md"
                        android:importantForAutofill="no" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ DETECTION SETTINGS SECTION ═══ -->
            <TextView
                android:id="@+id/tv_section_detection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_detection"
                style="@style/TextAppearance.SafeGuard.SectionHeader"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- Idle Detection -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_idle_detection"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_idle_detection"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_idle_detection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Auto Danger Detection -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_auto_danger"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_auto_danger"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_auto_danger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Idle Time Threshold -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_idle_threshold"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/et_idle_threshold"
                        android:layout_width="80dp"
                        android:layout_height="44dp"
                        android:hint="@string/hint_idle_minutes"
                        android:inputType="number"
                        android:text="15"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:gravity="center"
                        android:background="@drawable/bg_input_field"
                        android:padding="@dimen/spacing_sm"
                        android:importantForAutofill="no" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ TRIGGERS SECTION ═══ -->
            <TextView
                android:id="@+id/tv_section_triggers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_triggers"
                style="@style/TextAppearance.SafeGuard.SectionHeader"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- Shake Trigger -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_shake_trigger"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_shake_trigger"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_shake_trigger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Power Button Trigger -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_power_trigger"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_power_trigger"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_power_trigger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ EMERGENCY MESSAGE SECTION ═══ -->
            <TextView
                android:id="@+id/tv_section_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_message"
                style="@style/TextAppearance.SafeGuard.SectionHeader"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_emergency_message"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/et_emergency_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:maxLines="5"
                        android:hint="@string/hint_emergency_message"
                        android:text="@string/default_emergency_message"
                        android:inputType="textMultiLine"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:background="@drawable/bg_input_field"
                        android:padding="@dimen/spacing_md"
                        android:gravity="top"
                        android:importantForAutofill="no" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ BATTERY SECTION ═══ -->
            <TextView
                android:id="@+id/tv_section_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_battery"
                style="@style/TextAppearance.SafeGuard.SectionHeader"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:layout_marginTop="@dimen/spacing_sm" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_battery_optimization"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/monitoring_amber"
                        android:fontFamily="sans-serif-medium"
                        android:drawablePadding="@dimen/spacing_sm" />

                    <TextView
                        android:id="@+id/tv_battery_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/battery_info"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="@dimen/spacing_sm" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
